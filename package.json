{
  "name": "hs-boilerplate",
  "version": "3.1.0",
  "node version": "20.6.0",
  "description": "Boilerplate 2025 by MTG Team",
  "main": "main.js",
  "author": "MTG Team",
  "license": "MIT",
  "scripts": {
    "clean:dist": "rm -rf dist && mkdir dist ",
    "hs:auth": "hs auth",
    "module": "node generator.js",
    "dl:module": "node download_module.js",
    "upload:dev": "gulp upload",
    "upload:prod": "gulp upload --prod",
    "watch": "gulp watch",
    "build": "gulp build",
    "deploy:dev": "yarn clean:dist && yarn build && yarn upload:dev",
    "deploy:prod": "yarn clean:dist && yarn build && yarn upload:prod",
    "watch:dev": "yarn watch",
    "watch:prod": "yarn watch --prod"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@hubspot/cli": "^7.0.0",
