    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "dotenv": "^16.4.7",
    "dotenv-webpack": "^8.0.1",
    "glob": "^11.0.1",
    "gulp": "^5.0.0",
    "gulp-babel": "^8.0.0",
    "gulp-exec": "^5.0.0",
    "gulp-if": "^3.0.0",
    "gulp-newer": "^1.4.0",
    "gulp-plumber": "^1.2.1",
    "gulp-sass": "^6.0.0",
    "gulp-sass-glob-use-forward": "^0.1.3",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^3.2.5",
